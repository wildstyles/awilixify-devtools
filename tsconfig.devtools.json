{
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"removeComments": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"target": "es2022",
		"sourceMap": false,
		"strict": true,
		"allowJs": false,
		"strictPropertyInitialization": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": ["es2022"],
		"moduleDetection": "force",
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"noUncheckedIndexedAccess": true
	},
	"include": ["devtools/**/*.ts"],
	"exclude": ["node_modules", "dist", "devtools-ui"]
}
