{
	"name": "awilixify-devtools",
	"version": "0.0.0",
	"description": "Developer tools for inspecting Awilixify module graphs, routes, traces, and provider impact.",
	"keywords": [
		"awilixify",
		"awilix",
		"devtools",
		"dependency-injection",
		"di",
		"module-graph",
		"provider-impact",
		"tracing"
	],
	"homepage": "https://github.com/wildstyles/awilixify-devtools",
	"repository": {
		"type": "git",
		"url": "git://github.com/wildstyles/awilixify-devtools.git"
	},
	"type": "module",
	"main": "./dist/devtools/devtools.module.js",
	"types": "./dist/devtools/devtools.module.d.ts",
	"exports": {
		".": {
			"types": "./dist/devtools/devtools.module.d.ts",
			"import": "./dist/devtools/devtools.module.js"
		}
	},
	"files": [
		"README.md",
		"dist/*"
	],
	"scripts": {
		"build": "npm run build:devtools && npm run build:ui",
		"build:devtools": "tsc -p tsconfig.devtools.json",
		"build:ui": "vite build --config devtools-ui/vite.config.ts",
		"build:devtools:watch": "tsc -p tsconfig.devtools.json --watch --preserveWatchOutput",
		"build:ui:watch": "vite build --config devtools-ui/vite.config.ts --watch",
		"build:watch": "npm run build:devtools:watch & npm run build:ui:watch & wait",
		"build:release": "del-cli dist && npm run lint && npm run build",
		"check-types": "tsc -b",
		"dev": "vite --config devtools-ui/vite.config.ts",
		"generate:api": "orval",
		"lint": "biome check devtools devtools-ui/src devtools-ui/vite.config.ts",
		"lint:fix": "biome check --write devtools devtools-ui/src devtools-ui/vite.config.ts"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/static": "^9.1.3",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^6.0.0",
		"@mantine/code-highlight": "^9.4.0",
		"@mantine/core": "^8.3.8",
		"@mantine/hooks": "^8.3.8",
		"@sinclair/typebox": "^0.34.49",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-router": "^1.170.15",
		"@uiw/react-textarea-code-editor": "^3.1.1",
		"@xyflow/react": "^12.8.4",
		"clsx": "^2.1.1",
		"elkjs": "^0.10.0",
		"fastify": "^5.2.0",
		"highlight.js": "^11.11.1",
		"orval": "^8.18.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"ts-morph": "^28.0.0"
	},
	"peerDependencies": {
		"awilix": ">=9.0.0",
		"awilixify": ">=3.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@types/node": "^22.15.21",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^5.0.0",
		"del-cli": "^7.0.0",
		"typescript": "^5.8.0",
		"vite": "^7.0.0"
	}
}
